static int idx = -1';
Node* built(vector<int>&preorder){
    //without user input
    idx++;
    if(preorder[idx] == -1) return NULL;
    Node*root = new Node(preorder[idx]);
    root->left = built(preorder);
    root->right = built(preorder);
    return root;
}

//for input from user

Node*build(Node*root){
