#include <iostream>
#include <vector>
#include <queue>
#include <map>
using namespace std;
class Node{
    public:
    int data;
    Node*left;
    Node*right;
    Node(int d){
        data = d;
        left = right = NULL;
    }
};
//   #   if we compare tree then use this

Node* built(vector<int>&preorder,int &idx){
    //without user input
    idx++;
    if(preorder[idx] == -1) return NULL;
    Node*root = new Node(preorder[idx]);
    root->left = built(preorder,idx);
    root->right = built(preorder,idx);
    return root;
}

